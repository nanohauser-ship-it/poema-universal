                )}
              </div>
            </div>
          )}

          {status === "complete" &&
            reading && (
              <div className={styles.results}>
                <section
                  className={styles.resultHeader}
                >
                  <p>
                    Lectura bifocal
                  </p>

                  <h2>
                    {form.title.trim() ||
                      "Poema sin título"}
                  </h2>

                  <span>
                    {form.author.trim() ||
                      "Autor no indicado"}
                  </span>

                  <blockquote>
                    “
                    {
                      reading.labyrinth
                        .thresholdLine
                    }
                    ”
                  </blockquote>
                </section>

                <section
                  className={styles.twoEyes}
                >
                  <article
                    className={styles.labyrinthEye}
                  >
                    <div
                      className={
                        styles.eyeTitle
                      }
                    >
                      <span>01</span>

                      <div>
                        <p>
                          Ojo del laberinto
                        </p>

                        <h3>
                          La forma secreta
                        </h3>
                      </div>
                    </div>

                    <div
                      className={
                        styles.labyrinthSeal
                      }
                      aria-hidden="true"
                    >
                      <i />
                      <i />
                      <i />
                      <i />
                    </div>

                    <dl>
                      <div>
                        <dt>
                          Forma secreta
                        </dt>

                        <dd>
                          {
                            reading
                              .labyrinth
                              .secretForm
                          }
                        </dd>
                      </div>

                      <div>
                        <dt>
                          Centro oculto
                        </dt>

                        <dd>
                          {
                            reading
                              .labyrinth
                              .hiddenCenter
                          }
                        </dd>
                      </div>

                      <div>
                        <dt>
                          Bifurcación
                        </dt>

                        <dd>
                          {
                            reading
                              .labyrinth
                              .bifurcation
                          }
                        </dd>
                      </div>

                      <div>
                        <dt>Retorno</dt>

                        <dd>
                          {
                            reading
                              .labyrinth
                              .returnPath
                          }
                        </dd>
                      </div>
                    </dl>
                  </article>

                  <div
                    className={
                      styles.intersection
                    }
                  >
                    <p>Intersección</p>

                    <div>
                      <span />
                    </div>

                    <small>
                      Aquí se encuentran
                      la forma del poema y
                      la identidad de
                      quien lo recorre.
                    </small>
                  </div>

                  <article
                    className={styles.mirrorEye}
                  >
                    <div
                      className={
                        styles.eyeTitle
                      }
                    >
                      <span>02</span>

                      <div>
                        <p>
                          Ojo del espejo
                        </p>

                        <h3>
                          La identidad
