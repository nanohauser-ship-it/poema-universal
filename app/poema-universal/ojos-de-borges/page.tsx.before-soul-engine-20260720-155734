                        </h3>
                      </div>
                    </div>

                    <div
                      className={
                        styles.mirrorSeal
                      }
                      aria-hidden="true"
                    >
                      <i />
                      <i />
                    </div>

                    <dl>
                      <div>
                        <dt>
                          Identidad visible
                        </dt>

                        <dd>
                          {
                            reading.mirror
                              .visibleIdentity
                          }
                        </dd>
                      </div>

                      <div>
                        <dt>
                          Identidad reflejada
                        </dt>

                        <dd>
                          {
                            reading.mirror
                              .reflectedIdentity
                          }
                        </dd>
                      </div>

                      <div>
                        <dt>El doble</dt>

                        <dd>
                          {
                            reading.mirror
                              .double
                          }
                        </dd>
                      </div>

                      <div>
                        <dt>
                          Ausencia activa
                        </dt>

                        <dd>
                          {
                            reading.mirror
                              .activeAbsence
                          }
                        </dd>
                      </div>
                    </dl>
                  </article>
                </section>

                <section
                  className={
                    styles.symbolConstellation
                  }
                >
                  <p>
                    Constelación simbólica
                  </p>

                  <div>
                    {reading.symbols.map(
                      (symbol) => (
                        <span key={symbol}>
                          {symbol}
