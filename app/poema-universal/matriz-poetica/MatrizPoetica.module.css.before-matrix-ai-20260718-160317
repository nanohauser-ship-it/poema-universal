.page {
  --bg: #050607;
  --panel: rgba(15, 15, 14, 0.9);
  --gold: #c9a35f;
  --bright: #e1bf78;
  --ivory: #f0e8dc;
  --muted: rgba(240, 232, 220, 0.56);
  --faint: rgba(240, 232, 220, 0.29);
  --border: rgba(201, 163, 95, 0.22);

  min-height: 100vh;
  padding: 0 30px;
  overflow: hidden;
  background:
    radial-gradient(
      circle at 75% 20%,
      rgba(162, 111, 45, 0.15),
      transparent 31%
    ),
    radial-gradient(
      circle at 20% 65%,
      rgba(56, 65, 64, 0.13),
      transparent 35%
    ),
    var(--bg);
  color: var(--ivory);
}

.topbar {
  display: flex;
  max-width: 1480px;
  margin: 0 auto;
  padding-top: 27px;
  align-items: center;
  justify-content: space-between;
}

.brand {
  display: flex;
  align-items: center;
  gap: 11px;
  color: var(--bright);
  font-family: Arial, sans-serif;
  font-size: 10px;
  letter-spacing: 0.27em;
  text-decoration: none;
}

.topbar > p {
  margin: 0;
  color: rgba(201, 163, 95, 0.55);
  font-family: Arial, sans-serif;
  font-size: 8px;
  letter-spacing: 0.25em;
}

.hero {
  max-width: 820px;
  margin: 58px auto 50px;
  text-align: center;
}

.eyebrow,
.altar > p,
.grid article > p,
.scene > div:last-child > p {
  margin: 0;
  color: var(--gold);
  font-family: Arial, sans-serif;
  font-size: 8px;
  letter-spacing: 0.33em;
  text-transform: uppercase;
}

.hero h1 {
  margin: 14px 0 0;
  font-family: Georgia, serif;
  font-size: clamp(60px, 7vw, 104px);
  font-weight: 400;
  letter-spacing: -0.055em;
  line-height: 1;
}

.promise {
  margin: 18px 0 0;
  font-family: Georgia, serif;
  font-size: 20px;
}

.intro {
  max-width: 620px;
  margin: 17px auto 0;
  color: var(--muted);
  font-size: 13px;
  line-height: 1.8;
}

.layout {
  display: grid;
  grid-template-columns:
    minmax(300px, 390px)
    minmax(0, 1fr);
  gap: 22px;
  width: min(1480px, 100%);
  margin: 0 auto;
  align-items: start;
}

.sidebar {
  display: grid;
  position: sticky;
  top: 20px;
  gap: 18px;
}

.panel,
.empty,
.altar,
.grid article,
.scene,
.deleteArea {
  border: 1px solid var(--border);
  background:
    linear-gradient(
      145deg,
      rgba(26, 23, 19, 0.91),
      rgba(7, 9, 10, 0.95)
    );
  box-shadow:
    0 25px 80px rgba(0, 0, 0, 0.2);
}

.panel {
  padding: 23px;
}

.heading {
  display: flex;
  gap: 12px;
  margin-bottom: 20px;
  align-items: center;
  color: var(--gold);
}

.heading > span {
  font-size: 19px;
}

.heading h2 {
  margin: 0;
  color: var(--ivory);
  font-family: Arial, sans-serif;
  font-size: 9px;
  font-weight: 400;
  letter-spacing: 0.24em;
  text-transform: uppercase;
}

.heading p {
  margin: 5px 0 0;
  color: var(--faint);
  font-size: 10px;
}

.panel label {
  display: grid;
  position: relative;
  gap: 8px;
  margin-top: 15px;
}

.panel label > span {
  color: rgba(225, 191, 120, 0.77);
  font-family: Georgia, serif;
  font-size: 12px;
}

.panel input,
.panel select,
.panel textarea {
  width: 100%;
  box-sizing: border-box;
  border:
    1px solid rgba(240, 232, 220, 0.12);
  border-radius: 2px;
  outline: none;
  background: rgba(2, 4, 5, 0.6);
  color: var(--ivory);
  font: inherit;
}

.panel input,
.panel select {
  height: 43px;
  padding: 0 12px;
}

.panel textarea {
  min-height: 190px;
  resize: vertical;
  padding: 13px;
  line-height: 1.65;
}

.panel input:focus,
.panel select:focus,
.panel textarea:focus {
  border-color: rgba(201, 163, 95, 0.62);
}

.panel label small {
  position: absolute;
  right: 9px;
  bottom: 8px;
  color: var(--faint);
  font-size: 8px;
}

.panel > button {
  display: flex;
  width: 100%;
  min-height: 52px;
  margin-top: 20px;
  border: 1px solid #e3c47e;
  align-items: center;
  justify-content: center;
  gap: 10px;
  background:
    linear-gradient(
      110deg,
      #a97d39,
      #e0bc70,
      #a97d39
    );
  color: #1b140b;
  cursor: pointer;
  font-weight: 600;
}

.error {
  padding: 10px;
  border:
    1px solid rgba(180, 77, 57, 0.5);
  color: #e5a997;
  font-size: 11px;
}

.ethics article {
  position: relative;
  margin-top: 17px;
  padding-left: 19px;
}

.ethics article::before {
  position: absolute;
  top: 4px;
  left: 0;
  width: 6px;
  height: 6px;
  border: 1px solid var(--gold);
  border-radius: 50%;
  content: "";
}

.ethics strong {
  color: rgba(225, 191, 120, 0.84);
  font-family: Georgia, serif;
  font-size: 12px;
  font-weight: 400;
}

.ethics article p {
  margin: 4px 0 0;
  color: var(--faint);
  font-size: 10px;
  line-height: 1.5;
}

.results {
  min-width: 0;
}

.empty {
  display: grid;
  min-height: 760px;
  padding: 50px;
  place-items: center;
  align-content: center;
  text-align: center;
}

.empty > div {
  display: grid;
  width: 110px;
  height: 110px;
  place-items: center;
  border: 1px solid rgba(201, 163, 95, 0.42);
  border-radius: 50%;
  color: var(--bright);
  font-size: 32px;
}

.empty > p {
  margin: 28px 0 0;
  color: var(--gold);
  font-family: Arial, sans-serif;
  font-size: 8px;
  letter-spacing: 0.33em;
  text-transform: uppercase;
}

.empty h2 {
  max-width: 670px;
  margin: 18px 0;
  font-family: Georgia, serif;
  font-size: clamp(34px, 4.8vw, 61px);
  font-weight: 400;
  line-height: 1.08;
}

.empty > span {
  max-width: 560px;
  color: var(--muted);
  font-size: 13px;
  line-height: 1.8;
}

.stack {
  display: grid;
  gap: 16px;
}

.altar {
  min-height: 385px;
  padding: 55px;
  background:
    radial-gradient(
      circle at 76% 50%,
      rgba(205, 161, 82, 0.2),
      transparent 28%
    ),
    linear-gradient(
      135deg,
      rgba(7, 9, 10, 0.96),
      rgba(32, 24, 15, 0.94)
    );
}

.altar h2 {
  margin: 17px 0 6px;
  font-family: Georgia, serif;
  font-size: clamp(44px, 5.8vw, 78px);
  font-weight: 400;
  letter-spacing: -0.045em;
}

.altar > span {
  color: var(--muted);
  font-size: 11px;
}

.altar blockquote {
  max-width: 730px;
  margin: 52px 0 0;
  font-family: Georgia, serif;
  font-size: clamp(21px, 2.8vw, 34px);
  font-style: italic;
  line-height: 1.45;
}

.altar small {
  display: block;
  max-width: 670px;
  margin-top: 23px;
  color: var(--faint);
  line-height: 1.6;
}

.grid {
  display: grid;
  grid-template-columns:
    repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.grid article {
  min-height: 205px;
  padding: 30px;
}

.grid article > span,
.grid article h3,
.scene h3 {
  display: block;
  margin: 21px 0 0;
  color: rgba(240, 232, 220, 0.74);
  font-family: Georgia, serif;
  font-size: 17px;
  font-weight: 400;
  line-height: 1.72;
}

.scene {
  display: grid;
  grid-template-columns:
    minmax(360px, 1.25fr)
    minmax(260px, 0.75fr);
  min-height: 370px;
  overflow: hidden;
}

.sceneVisual {
  position: relative;
  min-height: 370px;
  overflow: hidden;
  background:
    radial-gradient(
      circle at 48% 37%,
      rgba(236, 195, 111, 0.3),
      transparent 25%
    ),
    linear-gradient(
      #171513,
      #08090a 68%,
      #21150a
    );
}

.light {
  position: absolute;
  top: 15%;
  left: 43%;
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background:
    radial-gradient(
      circle,
      rgba(255, 228, 169, 0.9),
      rgba(202, 155, 71, 0.22) 42%,
      transparent 72%
    );
  box-shadow:
    0 0 100px rgba(225, 181, 98, 0.32);
}

.book {
  position: absolute;
  bottom: 25%;
  left: 34%;
  width: 160px;
  height: 65px;
  transform:
    perspective(250px)
    rotateX(58deg);
  border: 1px solid rgba(240, 232, 220, 0.4);
  background:
    linear-gradient(
      90deg,
      #b7a37c 0 48%,
      #655236 49% 51%,
      #c7b58e 52%
    );
  box-shadow:
    0 0 55px rgba(227, 187, 103, 0.25);
}

.door {
  position: absolute;
  right: 12%;
  bottom: 17%;
  width: 85px;
  height: 175px;
  border: 3px solid rgba(131, 91, 45, 0.76);
}

.scene > div:last-child {
  align-self: center;
  padding: 36px;
}

.deleteArea {
  display: flex;
  padding: 24px 28px;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.deleteArea strong {
  font-family: Georgia, serif;
  font-size: 14px;
  font-weight: 400;
}

.deleteArea p {
  margin: 7px 0 0;
  color: var(--faint);
  font-size: 10px;
}

.deleteArea button {
  min-height: 43px;
  border:
    1px solid rgba(176, 75, 54, 0.52);
  background: rgba(110, 37, 25, 0.09);
  padding: 0 18px;
  color: #da8d79;
  cursor: pointer;
}

.footer {
  padding: 42px 20px;
  color: rgba(201, 163, 95, 0.57);
  font-family: Georgia, serif;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-align: center;
}

@media (max-width: 1000px) {
  .layout {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: static;
    grid-template-columns:
      repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 720px) {
  .page {
    padding: 0 12px;
  }

  .topbar > p {
    display: none;
  }

  .sidebar,
  .grid,
  .scene {
    grid-template-columns: 1fr;
  }

  .hero h1 {
    font-size: 56px;
  }

  .altar,
  .empty {
    padding: 35px 23px;
  }

  .deleteArea {
    align-items: stretch;
    flex-direction: column;
  }

  .deleteArea button {
    width: 100%;
  }
}
