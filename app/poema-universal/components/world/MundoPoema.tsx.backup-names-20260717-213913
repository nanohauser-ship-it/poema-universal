function Poet({
  position,
  rotation,
  color,
  task,
  phase,
  scale,
}: PoetData) {
  const group = useRef<THREE.Group>(null);
  const arm = useRef<THREE.Group>(null);

  useFrame(({ clock }) => {
    const t = clock.getElapsedTime() * 1.15 + phase;

    if (group.current) {
      group.current.position.y =
        position[1] + Math.sin(t) * 0.035;

      group.current.rotation.y =
        rotation + Math.sin(t * 0.35) * 0.06;
    }

    if (arm.current) {
      arm.current.rotation.x =
        -0.35 + Math.sin(t) * 0.28;
    }
  });

  return (
    <group
      ref={group}
      position={position}
      rotation={[0, rotation, 0]}
      scale={scale}
    >
      <mesh position={[0, 0.64, 0]} castShadow>
        <cylinderGeometry args={[0.2, 0.31, 0.92, 12]} />
        <meshStandardMaterial color={color} roughness={0.92} />
      </mesh>

      <mesh position={[0, 1.25, 0]} castShadow>
