.trigger {
  position: fixed;
  z-index: 99999;
  top: 50%;
  right: 18px;
  display: flex;
  width: 102px;
  flex-direction: column;
  align-items: flex-start;
  gap: 7px;
  padding: 18px 14px;
  transform: translateY(-50%);
  border: 1px solid rgba(215, 183, 117, 0.35);
  border-radius: 16px 0 0 16px;
  background: rgba(15, 12, 10, 0.94);
  color: #f3eadc;
  font-family: Georgia, "Times New Roman", serif;
  text-align: left;
  cursor: pointer;
  box-shadow: -18px 18px 60px rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(16px);
}

.trigger small {
  color: #d7b775;
  font-family: Arial, sans-serif;
  font-size: 9px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.symbol {
  color: #d7b775;
  font-size: 22px;
}

.book {
  position: fixed;
  z-index: 100000;
  top: 0;
  right: 0;
  display: grid;
  width: min(500px, 100vw);
  height: 100dvh;
  grid-template-columns: 25px minmax(0, 1fr);
  transform: translateX(105%);
  border-left: 1px solid rgba(215, 183, 117, 0.22);
  background:
    radial-gradient(
      circle at 75% 15%,
      rgba(173, 119, 54, 0.12),
      transparent 30%
    ),
    linear-gradient(
      180deg,
      rgba(22, 17, 12, 0.99),
      rgba(8, 9, 11, 0.99)
    );
  color: #f2e9dc;
  box-shadow: -35px 0 100px rgba(0, 0, 0, 0.55);
  transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
}

.open {
  transform: translateX(0);
}

.spine {
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: linear-gradient(
    180deg,
    #785631,
    #422b1a,
    #24160e
  );
  color: rgba(245, 222, 178, 0.5);
  font-size: 7px;
  letter-spacing: 0.22em;
  writing-mode: vertical-rl;
  transform: rotate(180deg);
}

.content {
  display: flex;
  min-width: 0;
  height: 100%;
  flex-direction: column;
  padding: 28px;
}

.header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20px;
}

.header h2 {
  max-width: 340px;
  margin: 8px 0 0;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 35px;
  font-weight: 400;
  line-height: 1;
}

.eyebrow {
  margin: 0;
  color: #d7b775;
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.close {
  width: 36px;
  height: 36px;
  border: 1px solid rgba(215, 183, 117, 0.2);
  border-radius: 50%;
  background: transparent;
  color: #f2e9dc;
  font-size: 24px;
  cursor: pointer;
}

.author {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
  margin-top: 25px;
  padding: 16px 0;
  border-top: 1px solid rgba(215, 183, 117, 0.14);
  border-bottom: 1px solid rgba(215, 183, 117, 0.14);
}

.author span {
  display: block;
  color: #b99b66;
  font-size: 8px;
  letter-spacing: 0.17em;
  text-transform: uppercase;
}

.author strong {
  display: block;
  margin-top: 8px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 17px;
  font-weight: 400;
}

.page {
  flex: 1;
  min-height: 0;
  margin-top: 22px;
  overflow-y: auto;
  animation: reveal 500ms ease both;
}

@keyframes reveal {
  from {
    opacity: 0;
    transform: translateX(12px);
  }

  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.number {
  margin: 0;
  color: #c7a667;
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
}

.page h3 {
  margin: 12px 0 0;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 34px;
  font-weight: 400;
  line-height: 1.05;
}

.poem {
  margin-top: 24px;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 17px;
  line-height: 1.75;
}

.poem p {
  margin: 0 0 8px;
}

.footer {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 12px;
  padding-top: 18px;
  border-top: 1px solid rgba(215, 183, 117, 0.14);
}

.footer button {
  min-height: 40px;
  border: 1px solid rgba(215, 183, 117, 0.22);
  border-radius: 999px;
  background: rgba(215, 183, 117, 0.06);
  color: #f2e9dc;
  cursor: pointer;
}

.footer span {
  color: rgba(242, 233, 220, 0.55);
  font-size: 11px;
}

@media (max-width: 620px) {
  .book {
    grid-template-columns: 17px minmax(0, 1fr);
  }

  .content {
    padding: 20px 17px;
  }

  .header h2 {
    font-size: 28px;
  }

  .page h3 {
    font-size: 28px;
  }

  .poem {
    font-size: 15px;
  }
}


.languageSwitch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-top: 18px;
  padding: 5px;
  border: 1px solid rgba(215, 183, 117, 0.16);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.025);
}

.languageButton {
  min-height: 36px;
  border: 0;
  border-radius: 999px;
  background: transparent;
  color: rgba(242, 233, 220, 0.55);
  font-size: 11px;
  letter-spacing: 0.04em;
  cursor: pointer;
  transition:
    color 180ms ease,
    background 180ms ease;
}

.languageButton:hover {
  color: rgba(246, 237, 226, 0.92);
}

.languageButtonActive {
  background: rgba(215, 183, 117, 0.13);
  color: #f6ede2;
  box-shadow:
    inset 0 0 0 1px
    rgba(215, 183, 117, 0.13);
}

.languageButton:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

.translationNote {
  margin: 12px 0 0;
  color: rgba(199, 166, 103, 0.68);
  font-size: 9px;
  font-style: italic;
  letter-spacing: 0.08em;
}


.languageSwitchSingle {
  grid-template-columns: 1fr;
}
